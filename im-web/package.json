{
  "name": "im-web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "proto:gen": "pbjs -t static-module -w es6 --es6 --path ../im-proto/proto ws/frame.proto body/messages.proto common/content.proto common/enums.proto -o src/proto/generated/bundle.js && pbts -o src/proto/generated/bundle.d.ts src/proto/generated/bundle.js",
    "typecheck": "tsc --noEmit",
    "build": "npm run proto:gen && tsc --noEmit && vite build",
    "preview": "vite preview --host 0.0.0.0",
    "lint": "eslint src --ext ts,tsx --max-warnings 0"
  },
  "dependencies": {
    "@ant-design/icons": "^5.6.1",
    "@tanstack/react-virtual": "^3.11.2",
    "antd": "^5.23.4",
    "axios": "^1.7.9",
    "dayjs": "^1.11.13",
    "json-bigint": "^1.0.0",
    "long": "^5.2.3",
    "protobufjs": "^7.4.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.29.0",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@types/json-bigint": "^1.0.4",
    "@types/node": "^22.10.10",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.18.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "postcss": "^8.5.1",
    "prettier": "^3.4.2",
    "protobufjs-cli": "^1.1.3",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.3",
    "vite": "^6.0.7"
  }
}
